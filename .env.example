# ─────────────────────────────────────────────
# CREDIXA - Variables de Entorno
# Copia este archivo como .env.local para desarrollo
# o .env para producción
# ─────────────────────────────────────────────

# Base de datos PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/credixa_db"

# JWT Secret - Cambia esto en producción por una cadena aleatoria segura
# Puedes generar una con: openssl rand -base64 64
JWT_SECRET="credixa-super-secret-jwt-key-cambiar-en-produccion-2025"

# URL de la aplicación
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# ALMACENAMIENTO DE ARCHIVOS (Cloudinary - Opcional)
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─────────────────────────────────────────────
# WHATSAPP API (Opcional)
# ─────────────────────────────────────────────
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""

# ─────────────────────────────────────────────
# EMAIL SMTP (Opcional)
# ─────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@credixa.com"

# ─────────────────────────────────────────────
# ENTORNO
# ─────────────────────────────────────────────
NODE_ENV="development"
